---
// AI 도구 상세 페이지: 공통 셸 + slug별 인터랙티브 위젯 (언어별 공용)
import BaseLayout from '../layouts/BaseLayout.astro';
import { languages, type Lang } from '../i18n/ui';
import { useTranslations, blogUrl } from '../i18n/utils';
import { toolsUi, tools, toolUrl, toolsIndexUrl } from '../i18n/tools';
import ToolAiCostCalculator from './tools/ToolAiCostCalculator.astro';
import ToolAiCapexGapExplorer from './tools/ToolAiCapexGapExplorer.astro';

interface Props { lang: Lang; slug: string; }
const { lang, slug } = Astro.props;
const tool = tools.find((x) => x.slug === slug)!;
const c = tool.copy[lang];
const g = toolsUi[lang];
const t = useTranslations(lang);
const alternates = Object.fromEntries(
  (Object.keys(languages) as Lang[]).map((l) => [l, toolUrl(slug, l)])
) as Partial<Record<Lang, string>>;
---
<BaseLayout lang={lang} title={c.title} description={c.tagline} alternates={alternates}>
  <article class="tool-page">
    <div class="wrap">
      <p class="backlink"><a href={toolsIndexUrl(lang)}>{g.backToList}</a></p>
      <h1>{c.title}</h1>
      <p class="tagline">{c.tagline}</p>

      {tool.appUrl ? (
        <div class="app-launch">
          <a class="launch-btn" href={`${tool.appUrl}?lang=${lang}`}>{g.openApp}</a>
          <p class="app-priv">🔒 {g.appPriv}</p>
        </div>
      ) : (
        <div class="tool-widget">
          {slug === 'ai-cost-calculator' && <ToolAiCostCalculator lang={lang} />}
          {slug === 'ai-capex-gap-explorer' && <ToolAiCapexGapExplorer lang={lang} />}
        </div>
      )}

      <section class="tool-about">
        <h2>{g.aboutTitle}</h2>
        {c.about.map((p) => <p>{p}</p>)}
      </section>

      {tool.relatedPost && (
        <a class="related-post" href={blogUrl(tool.relatedPost, lang)}>
          {t('readmore')} <span class="rp-arrow">→</span>
        </a>
      )}

      <p class="disclosure">{t('disclosure')}</p>
    </div>
  </article>
</BaseLayout>

<style>
  .tool-page { padding: 56px 0 90px; }
  .backlink { margin: 0 0 22px; font-size: 14px; }
  .tool-page h1 {
    font-family: var(--serif); font-weight: 600; font-size: clamp(1.7rem, 4vw, 2.6rem);
    color: var(--fg-strong); margin: 0 0 12px; letter-spacing: -0.01em;
  }
  .tagline { color: var(--muted); font-size: 1.1rem; max-width: var(--readw); margin: 0 0 32px; }
  .tool-widget { max-width: 760px; margin: 0 0 40px; }
  .app-launch {
    max-width: 760px; margin: 0 0 40px; padding: 30px 28px;
    border: 1px solid var(--border); border-radius: 14px;
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  .launch-btn {
    display: inline-block; padding: 13px 26px; border-radius: 10px;
    background: var(--accent); color: #fff; font-weight: 700; font-size: 1.05rem;
    text-decoration: none; transition: transform .12s ease, filter .12s ease;
  }
  .launch-btn:hover { transform: translateY(-2px); filter: brightness(1.08); }
  .app-priv { margin: 14px 0 0; font-size: 0.9rem; color: var(--muted); }
  .tool-about { max-width: var(--readw); padding-top: 12px; }
  .tool-about h2 { font-family: var(--serif); font-size: 1.2rem; color: var(--fg-strong); margin: 0 0 14px; }
  .tool-about p { color: var(--muted); font-size: 1.02rem; line-height: 1.75; margin: 0 0 16px; }
  .related-post {
    display: inline-flex; align-items: center; gap: 8px; margin: 10px 0 0;
    color: var(--accent); font-weight: 600; font-size: 15px;
  }
  .disclosure { max-width: var(--readw); margin: 30px 0 0; font-size: 0.85rem; color: var(--faint); line-height: 1.6; }
</style>
