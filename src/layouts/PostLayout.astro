---
import BaseLayout from './BaseLayout.astro';

// 마크다운 페이지의 frontmatter 가 여기로 들어옵니다.
const { frontmatter } = Astro.props;
const { title, description, date, author = 'Tech Decode' } = frontmatter;

const dateStr = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---
<BaseLayout title={title} description={description}>
  <article>
    <h1>{title}</h1>
    <p class="post-meta">By {author}{dateStr && ` · ${dateStr}`}</p>

    <!-- 광고 자리(상단). 애드센스 승인 후 여기에 광고 단위 코드가 들어갑니다. -->
    <div class="ad-slot" data-ad-slot="article-top"></div>

    <div class="post-body">
      <slot />
    </div>

    <p class="disclosure">
      This article may contain affiliate links. If you buy through them we may earn a small
      commission at no extra cost to you. Nothing here is financial or investment advice.
    </p>
  </article>
</BaseLayout>
