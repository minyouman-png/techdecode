---
import BaseLayout from '../layouts/BaseLayout.astro';

// 서브경로(/techdecode) 대응 base
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith('/') ? raw : raw + '/';

// blog 폴더의 모든 마크다운 글을 불러와 최신순으로 정렬합니다.
// 링크는 파일명(slug)으로 직접 만들어 base 를 확실히 붙입니다.
const modules = import.meta.glob('./blog/*.md', { eager: true });
const posts = Object.entries(modules)
  .map(([path, m]) => {
    const slug = path.split('/').pop().replace(/\.md$/, '');
    return { ...m.frontmatter, href: `${base}blog/${slug}/` };
  })
  .sort((a, b) => new Date(b.date) - new Date(a.date));
---
<BaseLayout>
  <h1>Tech Decode</h1>
  <p class="lede">Clear, no-hype analysis of tech, chips, and the markets that move them.</p>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a class="title" href={post.href}>{post.title}</a>
        {post.description && <p class="excerpt">{post.description}</p>}
      </li>
    ))}
  </ul>
</BaseLayout>
