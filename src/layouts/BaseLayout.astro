---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME, htmlLang, type Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  // hreflang 및 언어 전환기용 대응 URL
  alternates: Partial<Record<Lang, string>>;
}
const { lang, title, description, alternates } = Astro.props;
const t = useTranslations(lang);

const fullTitle = title ? `${title} — ${SITE_NAME}` : `${SITE_NAME} — ${t('tagline')}`;
const desc = description ?? t('metaDescription');
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// 애드센스 승인 후 여기에 'ca-pub-XXXXXXXXXXXXXXXX' 를 넣으면 광고 로더가 켜집니다.
const ADSENSE_PUBLISHER_ID = '';
---
<!doctype html>
<html lang={htmlLang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta name="google-site-verification" content="Vlehh_NC5drUpj3OCzbr48VPtCNTlL20dHI1HQCL4Ok" />
    <meta name="naver-site-verification" content="8308368b2377cbbbd03c2db29c88cf5524ea888d" />
    <link rel="canonical" href={canonical} />

    {Object.entries(alternates).map(([code, href]) => (
      <link rel="alternate" hreflang={code} href={new URL(href, Astro.site).href} />
    ))}
    {alternates.en && <link rel="alternate" hreflang="x-default" href={new URL(alternates.en, Astro.site).href} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    {ADSENSE_PUBLISHER_ID && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_PUBLISHER_ID}`}
        crossorigin="anonymous"></script>
    )}

    <!-- GoatCounter 방문자 집계 (쿠키 없음, localhost 자동 제외) -->
    <script data-goatcounter="https://minyouman.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
  </head>
  <body>
    <Header lang={lang} alternates={alternates} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
